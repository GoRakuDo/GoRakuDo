---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/pages/project/project-lp.css';

// SVG Icons
const BookOpenIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`;
const GithubIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`;
const ChevronRightIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>`;

// Feature Icons
const PaletteIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>`;
const SmartphoneIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`;
const ZapIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`;

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { title, tagline, description, accentColor, githubUrl } = project.data;

// In a real scenario, this would be fetched from `getCollection('project-docs')` filtered by `project: project.slug`.
// For the mockup phase, we'll construct the DenChou structure manually to guarantee the exact visual output.
const docsCategories = [
  {
    title: "[ SETUP & BASIC ]",
    links: [
      { text: "Setup Overview", url: "#" },
      { text: "Mobile Layout", url: "#" },
      { text: "Deck Presets", url: "#" }
    ]
  },
  {
    title: "[ FEATURES ]",
    links: [
      { text: "Scene Switching", url: "#" },
      { text: "Lightbox Media", url: "#" },
      { text: "Kanji Hover (Jitendex)", url: "#" }
    ]
  },
  {
    title: "[ CUSTOMIZATION ]",
    links: [
      { text: "Preferences", url: "#" },
      { text: "Custom CSS / Dark Mode", url: "#" }
    ]
  }
];

---

<BaseLayout 
  title={`${title} - Project LP | GoRakuDo`} 
  description={description}
  pageType="website"
  lang="id"
>
  <main class="project-lp-layout" style={`--project-accent: ${accentColor || 'var(--grkd-brand-secondary)'};`}>
    
    <!-- Hero Section -->
    <section class="lp-hero">
      <div class="lp-hero-content">
        <div class="lp-marker">/// ARTIFACT_CLASS: ANKI_NOTE ///</div>
        <h1 class="lp-title">{title}</h1>
        <p class="lp-tagline">{tagline}</p>
        <p class="lp-desc">{description}</p>
        
        <div class="lp-actions">
          <a href="#docs" class="lp-btn-primary">
            <Fragment set:html={BookOpenIcon} />
            Baca Dokumentasi
          </a>
          {githubUrl && (
            <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="lp-btn-secondary">
              <Fragment set:html={GithubIcon} />
              GitHub Repo
            </a>
          )}
        </div>
      </div>
      
      <div class="lp-hero-visual">
        <div class="lp-hero-glow"></div>
        <img 
          src="/page_images/project/DenChou/denchou_showcase.gif" 
          alt="DenChou UI Demo" 
          class="lp-hero-gif"
          loading="eager"
        />
      </div>
    </section>

    <!-- Features Grid -->
    <section class="lp-features">
      <h2 class="lp-section-title">/// FITUR_UTAMA ///</h2>
      <div class="lp-features-grid">
        
        <!-- Feature 1 -->
        <div class="lp-feature-card">
          <div class="lp-feature-icon">
            <Fragment set:html={PaletteIcon} />
          </div>
          <h3 class="lp-feature-title">Pure Black/White Dilarang</h3>
          <p class="lp-feature-desc">Semua warna berbasis OKLCH untuk harmoni visual yang sempurna, menghindari kontras menyilaukan ala web lama.</p>
        </div>

        <!-- Feature 2 -->
        <div class="lp-feature-card">
          <div class="lp-feature-icon">
            <Fragment set:html={SmartphoneIcon} />
          </div>
          <h3 class="lp-feature-title">AnkiDroid-First Layout</h3>
          <p class="lp-feature-desc">Dibangun dengan Container Query dan overflow hidden guard untuk mencegah bug scrolling di layar kecil AnkiDroid.</p>
        </div>

        <!-- Feature 3 -->
        <div class="lp-feature-card">
          <div class="lp-feature-icon">
            <Fragment set:html={ZapIcon} />
          </div>
          <h3 class="lp-feature-title">Buttery Smooth Animation</h3>
          <p class="lp-feature-desc">Menggunakan custom easing <code>cubic-bezier(0.23, 1, 0.32, 1)</code> dan animasi berbasis GPU (max-height dihindari) untuk transisi super mulus.</p>
        </div>

      </div>
    </section>

    <!-- Docs Index -->
    <section id="docs" class="lp-docs-index">
      <h2 class="lp-section-title">/// DOKUMENTASI_TERSEDIA ///</h2>
      <div class="lp-docs-grid">
        
        {docsCategories.map((category) => (
          <div class="lp-docs-category">
            <h3 class="lp-docs-category-title">{category.title}</h3>
            <ul class="lp-docs-list">
              {category.links.map((link) => (
                <li>
                  <a href={link.url} class="lp-docs-link">
                    <Fragment set:html={ChevronRightIcon} />
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

      </div>
    </section>
    
  </main>
</BaseLayout>