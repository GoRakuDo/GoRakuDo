---
import { getCollection } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;

// For the root LP, no specific doc is active
const activeDocSlug = undefined;

// We will eventually load this from getCollection('project-docs')
const docsCategories = [
  {
    title: "[ SETUP & BASIC ]",
    links: [
      { text: "Setup Overview", url: "/project/denchou/setup-overview", slug: "setup-overview" },
      { text: "Mobile Layout", url: "/project/denchou/mobile-layout", slug: "mobile-layout" },
      { text: "Deck Presets", url: "/project/denchou/deck-presets", slug: "deck-presets" }
    ]
  },
  {
    title: "[ FEATURES ]",
    links: [
      { text: "Scene Switching", url: "/project/denchou/scene-switching", slug: "scene-switching" },
      { text: "Lightbox Media", url: "/project/denchou/lightbox-media", slug: "lightbox-media" },
      { text: "Kanji Hover (Jitendex)", url: "/project/denchou/kanji-hover", slug: "kanji-hover" }
    ]
  },
  {
    title: "[ CUSTOMIZATION ]",
    links: [
      { text: "Preferences", url: "/project/denchou/preferences", slug: "preferences" },
      { text: "Custom CSS / Dark Mode", url: "/project/denchou/custom-css", slug: "custom-css" }
    ]
  }
];
---

<ProjectLayout project={project} activeDocSlug={activeDocSlug} docsCategories={docsCategories} />
