---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import { buildDocsCategories } from '../../utils/project-docs';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props as { project: CollectionEntry<'projects'> };

const activeDocSlug = undefined;

const allDocs = await getCollection('project-docs');
const projectDocs: CollectionEntry<'project-docs'>[] = allDocs.filter(
  (doc) => doc.data.parentProject === project.slug,
);

const docsCategories = buildDocsCategories(projectDocs, project.slug);
---

<ProjectLayout project={project} activeDocSlug={activeDocSlug} docsCategories={docsCategories} />
