---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ProjectLayout from '../../../layouts/ProjectLayout.astro';
import { getProjectDocSlug } from '../../../utils/project-docs';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const docs = await getCollection('project-docs');
  return projects.flatMap(p => {
    const projectDocs = docs.filter(d => d.data.parentProject === p.slug && d.data.status === 'published' && getProjectDocSlug(d.id) !== 'index');
    return projectDocs.map(doc => {
      const docSlug = getProjectDocSlug(doc.id);
      return {
        params: { project: p.slug, doc_slug: docSlug },
        props: { project: p, doc: doc, allDocs: projectDocs },
      };
    });
  });
}

const { project, doc, allDocs } = Astro.props as {
  project: CollectionEntry<'projects'>;
  doc: CollectionEntry<'project-docs'>;
  allDocs: CollectionEntry<'project-docs'>[];
};
const { Content } = await render(doc);

const sortedDocs: CollectionEntry<'project-docs'>[] = [...allDocs]
  .filter((d) => d.data.status === 'published')
  .sort((a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title));
const chunkSize = Math.ceil(sortedDocs.length / 3);

const docsCategories = [
  {
    title: "[ PART 1 ]",
    links: sortedDocs.slice(0, chunkSize).map(d => ({
      text: d.data.title,
      url: `/project/${project.slug}/${getProjectDocSlug(d.id)}`,
      slug: getProjectDocSlug(d.id)
    }))
  },
  {
    title: "[ PART 2 ]",
    links: sortedDocs.slice(chunkSize, chunkSize * 2).map(d => ({
      text: d.data.title,
      url: `/project/${project.slug}/${getProjectDocSlug(d.id)}`,
      slug: getProjectDocSlug(d.id)
    }))
  },
  {
    title: "[ PART 3 ]",
    links: sortedDocs.slice(chunkSize * 2).map(d => ({
      text: d.data.title,
      url: `/project/${project.slug}/${getProjectDocSlug(d.id)}`,
      slug: getProjectDocSlug(d.id)
    }))
  }
];

const docSlug = getProjectDocSlug(doc.id);
---

<ProjectLayout project={project} activeDocSlug={docSlug} docsCategories={docsCategories}>
  <article class="lp-doc-article prose prose-invert max-w-none p-8">
    <Content />
  </article>
</ProjectLayout>
