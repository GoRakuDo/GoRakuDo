---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ProjectLayout from '../../../layouts/ProjectLayout.astro';
import { getProjectDocSlug, buildDocsCategories } from '../../../utils/project-docs';
import '../../../styles/pages/project/project-doc.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const docs = await getCollection('project-docs');
  return projects.flatMap(p => {
    const projectDocs = docs.filter(d => d.data.parentProject === p.slug && d.data.status === 'published' && getProjectDocSlug(d.id) !== 'index');
    return projectDocs.map(doc => {
      const docSlug = getProjectDocSlug(doc.id);
      return {
        params: { project: p.slug, doc_slug: docSlug },
        props: { project: p, doc: doc, allDocs: projectDocs },
      };
    });
  });
}

const { project, doc, allDocs } = Astro.props as {
  project: CollectionEntry<'projects'>;
  doc: CollectionEntry<'project-docs'>;
  allDocs: CollectionEntry<'project-docs'>[];
};
const { Content } = await render(doc);

const docsCategories = buildDocsCategories(allDocs, project.slug);
const docSlug = getProjectDocSlug(doc.id);
const seoTitle = `${project.data.title}: ${doc.data.title}・GoRakuDo 語楽道`;
---

<ProjectLayout project={project} activeDocSlug={docSlug} docsCategories={docsCategories} seoTitle={seoTitle}>
  <div class='tqa-page'>
    <div class='tqa-grid'>
      <main class='tqa-main' role='main'>
        <article class='tqa-article' id='main-content'>
          <Content />
        </article>
        <footer class='tqa-end' role='contentinfo'>
          <p class='tqa-end-marker' aria-hidden='true'>/// QUEST_LOG_CLOSE ///</p>
        </footer>
      </main>
    </div>
  </div>
</ProjectLayout>
