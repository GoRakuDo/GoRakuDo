---
// src/pages/project/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { generateBreadcrumbSchema } from '../../utils/breadcrumb-schema';
import '../../styles/pages/project/project-hub.css';

// ==============================
// 1. Fetch Projects Data
// ==============================
const projects = await getCollection('projects', ({ data }) => {
  return data.status !== 'archived';
});

// For now, if we don't have images in frontmatter, we can assign a fallback image
const getBannerImage = (project: any) => {
  if (project.data.heroImage) return project.data.heroImage;
  // Fallback for DenChou
  if (project.slug === 'denchou') return '/page_images/homepage/old_rules_statue.webp';
  return '/page_images/homepage/old_rules_statue.webp'; // generic fallback
};

// ==============================
// 2. SEO & Schema
// ==============================
const title = "GoRakuDo Projects";
const description = "Ruang pameran artefak pembelajaran (tools dan sistem) orisinal yang dikembangkan oleh GoRakuDo.";

const breadcrumbSchema = generateBreadcrumbSchema({
  items: [
    { title: 'Home', url: '/', isActive: false },
    { title: 'Projects', url: '/project', isActive: true },
  ],
  siteUrl: String(Astro.site || 'https://gorakudo.org'),
});
---

<BaseLayout
  title={title}
  description={description}
  pageType="website"
  lang="id"
  breadcrumbSchema={breadcrumbSchema}
>
  <main class="project-hub-layout" role="main" aria-label="GoRakuDo Projects Showcase">
    
    <!-- Hub Header -->
    <header class="hub-header-wrapper" transition:name="project-hub-header">
      <div class="hub-marker" aria-hidden="true">/// ARTIFACT_SHOWCASE ///</div>
      <h1 class="hub-title">GoRakuDo Projects</h1>
      <p class="hub-subtitle">
        Project original yang dirancang dan dikembangkan oleh GoRakuDo.
        Kumpulan sistem dan tools yang mendukung metode belajar Immersion.
      </p>
    </header>

    <!-- Banners Grid -->
    <div class="project-banners-grid">
      {projects.map((project) => {
        const accentColor = project.data.accentColor || 'var(--grkd-brand-secondary)';
        
        return (
          <a 
            href={`/project/${project.slug}`} 
            class="project-banner"
            style={`--project-accent: ${accentColor};`}
            aria-label={`${project.data.title} project page`}
          >
            <!-- Content Area (Left) -->
            <div class="banner-content">
              <h2 class="banner-title" transition:name={`project-title-${project.slug}`}>
                {project.data.title}
              </h2>
              
              <div class="banner-tagline">
                {project.data.tagline}
              </div>
              
              <p class="banner-desc">
                {project.data.description}
              </p>
            </div>

            <!-- Background Image Area (Right) -->
            <div class="banner-bg-wrapper">
              <img 
                src={getBannerImage(project)} 
                alt="" 
                class="banner-bg-image" 
                loading="lazy" 
                decoding="async" 
              />
            </div>

            <!-- Watermark Text (Absolute) -->
            <div class="banner-watermark">{project.data.title.toUpperCase()}</div>
          </a>
        );
      })}
    </div>

  </main>
</BaseLayout>
