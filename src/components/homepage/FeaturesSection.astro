---
import FeatureCard from './FeatureCard.astro';
import petaJalanImg from '../../assets/images/features/peta_jalan_terstruktur.webp';
import slaCoreImg from '../../assets/images/features/sla_daptive_core.webp';

interface Feature {
  id: string;
  svgPath: string;
  type: string;
  title: string;
  description: string;
  image?: ImageMetadata;
}

interface Props {
  title?: string;
  features?: Feature[];
}

const {
  title = 'Fitur Utama',
  features = [
    {
      id: 'ARTF-01',
      svgPath: '<rect width="16" height="16" x="4" y="4" rx="2" /><rect width="6" height="6" x="9" y="9" rx="1" /><path d="M15 2v2" /><path d="M15 20v2" /><path d="M2 15h2" /><path d="M2 9h2" /><path d="M20 15h2" /><path d="M20 9h2" /><path d="M9 2v2" /><path d="M9 20v2" />',
      type: 'Core Engine',
      title: '言語習得理論に基づく',
      description:
        'Tinggalkan hafalan robotik. Engine ini mensimulasikan akuisisi bahasa alami otak manusia. Semakin sering kamu membaca, semakin cerdas sistem beradaptasi.',
      image: slaCoreImg,
    },
    {
      id: 'ARTF-02',
      svgPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />',
      type: 'Guild Network',
      title: 'Immersion Syndicate',
      description:
        'Kamu tidak berjuang sendirian. Terhubung dengan sesama pembelajar dan penutur asli dalam frekuensi yang sama. Sinkronisasi motivasi real-time.',
    },
    {
      id: 'ARTF-03',
      svgPath: '<path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z" /><path d="M15 5.764v15" /><path d="M9 3.236v15" />',
      type: 'Navigation Map',
      title: 'Nativeness Blueprint',
      description:
        'Cetak biru menuju kefasihan sejati. Navigasi rahasia langkah-demi-langkah dari kana dasar hingga menaklukkan media kompleks tanpa tersesat.',
      image: petaJalanImg,
    },
    {
      id: 'ARTF-04',
      svgPath: '<path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3" />',
      type: 'Passive Skill',
      title: 'Native Resonance',
      description:
        'Bypass filter terjemahan di otakmu. Kembangkan kemampuan pasif untuk menyerap dan merasakan bahasa Jepang secara instan layaknya bahasa ibu.',
    },
    {
      id: 'ARTF-05',
      svgPath: '<path d="M3 7V5a2 2 0 0 1 2-2h2" /><path d="M17 3h2a2 2 0 0 1 2 2v2" /><path d="M21 17v2a2 2 0 0 1-2 2h-2" /><path d="M7 21H5a2 2 0 0 1-2-2v-2" />',
      type: 'Legendary Tool',
      title: 'Context Extractor',
      description:
        'Senjata pamungkas penambang kosakata. Tembak kata tak dikenal dari anime, ubah jadi flashcard Anki otomatis dalam hitungan milidetik.',
    },
    {
      id: 'ARTF-06',
      svgPath: '<path d="m16 6 4 14" /><path d="M12 6v14" /><path d="M8 8v12" /><path d="M4 4v16" />',
      type: 'Field Spell',
      title: 'The Akashic Vault',
      description:
        'Buka gerbang menuju harta karun media Jepang tanpa batas. Kurasi anime dan manga tingkat dewa yang disesuaikan persis dengan level EXP-mu.',
    },
  ],
} = Astro.props;
---

<section
  class='features-section loading'
  transition:name='features-section'
  data-lazy
>
  <div class='features-container'>
    <div class='features-header-wrapper'>
      <h2
        class='features-title'
        id='features-title'
        transition:name='features-title'
      >
        {title}
      </h2>
      <p class='features-subtitle'>Senjata Rahasia Menuju Nativeness</p>
    </div>
    <div class='features-grid'>
      {
        features.map((feature, index) => (
          <FeatureCard
            id={feature.id}
            svgPath={feature.svgPath}
            type={feature.type}
            title={feature.title}
            description={feature.description}
            image={feature.image}
            index={index + 1}
          />
        ))
      }
    </div>
  </div>
</section>
