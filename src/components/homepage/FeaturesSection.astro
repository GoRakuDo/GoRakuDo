---
import FeatureCard from './FeatureCard.astro';
import petaJalanImg from '../../assets/images/features/peta_jalan_terstruktur.webp';

interface Feature {
  icon: string;
  type: string;
  title: string;
  description: string;
  image?: ImageMetadata;
}

interface Props {
  title?: string;
  features?: Feature[];
}

const {
  title = 'Fitur Utama',
  features = [
    {
      icon: '⚡',
      type: 'Core Engine',
      title: 'Adaptive Learning',
      description:
        'Rekomendasi yang didukung oleh Metodologi SLA (Ilmu Pembelajaran Bahasa ke-2) terbaru yang sesuai cara otak dirancang untuk memperoleh bahasa—melalui paparan bermakna, bukan sekedar hafalan.',
    },
    {
      icon: '🤜🤛',
      type: 'Guild Network',
      title: 'Belajar Bersama Komunitas',
      description:
        'Bergabunglah dengan sesama pembelajar dan penutur asli dalam lingkungan komunitas yang mendukung.',
    },
    {
      icon: '📚',
      type: 'Navigation Map',
      title: 'Peta Jalan Terstruktur',
      description:
        'Tahapan yang jelas dan dapat dicapai dari kana dasar hingga media kompleks. Setiap langkah dibangun secara alami dari yang sebelumnya.',
      image: petaJalanImg,
    },
    {
      icon: '🧠',
      type: 'Passive Skill',
      title: 'Berpikir dalam Jepang',
      description:
        'Melampaui terjemahan. Kembangkan kemampuan untuk memahami dan merasakan bahasa Jepang secara instan, seperti penutur asli.',
    },
    {
      icon: '📸',
      type: 'Legendary Tool',
      title: 'Sentence Miner',
      description:
        'Ekstrak kosakata tak dikenal dari konteks asli manga atau anime hanya dengan satu klik dan ubah menjadi flashcard Anki otomatis.',
    },
    {
      icon: '🎮',
      type: 'Field Spell',
      title: 'Content Library',
      description:
        'Harta karun konten Jepang asli (anime, manga, VTuber) yang dikurasi sesuai levelmu, dari pemula hingga mahir.',
    },
  ],
} = Astro.props;
---

<section
  class='features-section loading'
  transition:name='features-section'
  data-lazy
>
  <div class='features-container'>
    <div class='features-header-wrapper'>
      <h2
        class='features-title'
        id='features-title'
        transition:name='features-title'
      >
        {title}
      </h2>
      <p class='features-subtitle'>Senjata Rahasia Menuju Nativeness</p>
    </div>
    <div class='features-grid'>
      {
        features.map((feature, index) => (
          <FeatureCard
            icon={feature.icon}
            type={feature.type}
            title={feature.title}
            description={feature.description}
            image={feature.image}
            index={index + 1}
          />
        ))
      }
    </div>
  </div>
</section>
