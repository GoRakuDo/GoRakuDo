---
/**
 * AwakeningSection.astro
 * Solo Leveling "System Notification" glassmorphism aesthetic.
 */
---

<section
  id="awakening"
  class="relative w-full overflow-hidden py-16 lg:py-24"
  aria-label="Metode Tradisional vs Pendekatan Immersion"
  data-lazy
>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- ==========================================
         ROW 1: TRADITIONAL (2-Column Split)
         ========================================== -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      
      <!-- LEFT: Statue Image -->
      <div class="relative flex justify-center lg:justify-end">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-[radial-gradient(circle_at_center,oklch(20%_0.04_20deg/0.4)_0%,transparent_60%)] blur-2xl pointer-events-none"></div>
        <img 
          src="/page_images/homepage/old_rules_statue.webp" 
          alt="Patung memegang prasasti aturan lama"
          class="relative w-full max-w-[400px] lg:max-w-[540px] object-contain mix-blend-luminosity statue-fade"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- RIGHT: Traditional Text -->
      <div class="relative z-10 flex flex-col justify-center text-center lg:text-left">
        <h2 class="traditional-title">= 従来日本語学習条約 =</h2>
        <p class="traditional-subtitle">Perjanjian Belajar Bahasa Jepang Tradisional</p>
        
        <ul class="traditional-rules">
          <li>
            <span class="numeral">I.</span> 
            <span>Sembah tabel tata bahasa.</span>
          </li>
          <li>
            <span class="numeral">II.</span>
            <span>Takutlah pada kesalahan.</span>
          </li>
          <li>
            <span class="numeral">III.</span>
            <span>Ujian JLPT adalah segalanya.</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- ==========================================
         ROW 2 & 3: AWAKENING SYSTEM (Glassmorphism Hologram)
         ========================================== -->
    <div class="sl-panel-wrapper relative z-20 w-full max-w-2xl mx-auto -mt-4 lg:-mt-12">
      
      <!-- Top Glowing Bracket -->
      <div class="sl-bracket-top"></div>

      <!-- Glass Body (Navbar-like Glassmorphism) -->
      <div class="sl-glass-body">
        
        <!-- Header: (!) NOTIFICATION -->
        <header class="sl-header">
          <div class="sl-icon-circle" aria-hidden="true">
            <span class="sl-exclamation">!</span>
          </div>
          <h3 class="sl-title">SYSTEM NOTIFICATION</h3>
        </header>

        <!-- Content -->
        <div class="sl-content text-center">
          <p class="sl-subtitle">Hidden quest requirements met.</p>
          <p class="sl-quest-name">- [ Awakening: Pendekatan Immersion ] -</p>

          <div class="sl-rules-list">
            <article class="sl-rule">
              <span class="sl-rule-bullet" aria-hidden="true">&gt;</span>
              <p>Buang buku teks lamamu.</p>
            </article>
            <article class="sl-rule">
              <span class="sl-rule-bullet" aria-hidden="true">&gt;</span>
              <p>Tonton anime tanpa henti.</p>
            </article>
            <article class="sl-rule">
              <span class="sl-rule-bullet" aria-hidden="true">&gt;</span>
              <p>Konteks adalah rajanya.</p>
            </article>
            <article class="sl-rule">
              <span class="sl-rule-bullet" aria-hidden="true">&gt;</span>
              <p>Menikmati adalah satu-satunya aturan.</p>
            </article>
          </div>

          <div class="sl-action-container mt-8">
            <p class="sl-action-prompt mb-4 text-[var(--token-white-base,white)] font-bold tracking-widest text-xs opacity-80">Apakah kamu menerima?</p>
            <div class="flex justify-center gap-8">
              <button class="sl-btn sl-btn-accept" aria-label="Terima pendekatan immersion">[ ACCEPT ]</button>
            </div>
          </div>

        </div>
      </div>

      <!-- Bottom Glowing Bracket -->
      <div class="sl-bracket-bottom"></div>
      
    </div>

  </div>
</section>

<style>
  /* ==========================================================================
     TRADITIONAL SECTION (ROW 1)
     ========================================================================== */
  
  .statue-fade {
    opacity: 0.85;
    filter: drop-shadow(0 10px 30px oklch(0% 0 0deg / 0.8));
    mask-image: linear-gradient(to bottom, black 65%, transparent 100%);
  }

  .traditional-title {
    margin-bottom: 0.5rem;
    color: oklch(45% 0.08 20deg / 0.8);
    font-family: var(--font-noto-serif-jp, 'Noto Serif JP', serif);
    font-size: 1.75rem;
    font-weight: 900;
    text-align: center;
    letter-spacing: 0.1em;
  }

  @media (min-width: 1024px) {
    .traditional-title { font-size: 2.25rem; }
  }

  .traditional-subtitle {
    margin-bottom: 3.5rem;
    color: oklch(45% 0.08 20deg / 0.8); /* Matched to title */
    font-family: var(--font-noto-serif-jp, 'Noto Serif JP', serif);
    font-size: 1.25rem;
    font-weight: 900; /* Matched to title */
    text-align: center;
    letter-spacing: 0.1em; /* Matched to title */
  }

  .traditional-rules {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 560px;
    margin: 0;
    padding: 0;
    text-align: left;
    list-style: none;
  }

  @media (max-width: 1023px) {
    .traditional-rules { margin: 0 auto; }
  }

  .traditional-rules li {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    color: oklch(45% 0.08 20deg / 0.8);
    font-family: var(--font-noto-serif-jp, 'Noto Serif JP', serif);
    font-size: 1.35rem;
    font-weight: 750;
    line-height: 1.5;
    letter-spacing: 0.02em;
  }

  .traditional-rules li span:not(.numeral) {
    color: inherit;
  }

  .traditional-rules .numeral {
    min-width: 2.5rem;
    color: inherit;
    font-size: 1.15em;
    font-weight: 900;
  }

  /* ==========================================================================
     SYSTEM HOLOGRAM PANEL (SOLO LEVELING STYLE)
     ========================================================================== */

  .sl-panel-wrapper {
    /* Floating animation */
    animation: floatPanel 6s ease-in-out infinite alternate;
  }

  @keyframes floatPanel {
    0% { transform: translateY(0); }

    100% { transform: translateY(-8px); }
  }

  /* --- Glowing Brackets --- */
  .sl-bracket-top, .sl-bracket-bottom {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 4px;
    border-radius: 2px;
    background: var(--grkd-cyan-400, oklch(70% 0.15 195deg));
    box-shadow: 
      0 0 10px var(--grkd-cyan-400, oklch(70% 0.15 195deg)), 
      0 0 20px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  /* Inner hot-white core for the brackets */
  .sl-bracket-top::after, .sl-bracket-bottom::after {
    position: absolute;
    inset: 1px 10%;
    border-radius: 2px;
    background: var(--token-white-base, white);
    content: '';
    box-shadow: 0 0 6px white;
  }

  /* --- Glassmorphism Body (Navbar Style) --- */
  .sl-glass-body {
    position: relative;
    z-index: 1;
    margin: 0 16px; /* Inset from the brackets */
    padding: 2rem 1.5rem;
    border-right: 2px solid var(--grkd-cyan-400, oklch(70% 0.15 195deg));
    
    /* Sharp glowing side borders */
    border-left: 2px solid var(--grkd-cyan-400, oklch(70% 0.15 195deg));
    
    /* High contrast dark glass */
    background: linear-gradient(
      135deg,
      oklch(15% 0.08 260deg / 0.65) 0%,
      oklch(10% 0.05 270deg / 0.8) 50%,
      oklch(15% 0.08 260deg / 0.65) 100%
    );
    backdrop-filter: blur(16px) saturate(120%);
    
    /* Inner ambient glow */
    box-shadow: 
      inset 0 0 30px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg / 0.4)),
      0 10px 30px oklch(0% 0 0deg / 0.5);
  }

  @media (min-width: 768px) {
    .sl-glass-body { padding: 2.5rem 3rem; }
  }

  /* Tech Grid Scanline Overlay */
  .sl-glass-body::before {
    position: absolute;
    z-index: -1;
    background-image: 
      linear-gradient(0deg, transparent 24%, oklch(100% 0 0deg / 0.03) 25%, oklch(100% 0 0deg / 0.03) 26%, transparent 27%, transparent 74%, oklch(100% 0 0deg / 0.03) 75%, oklch(100% 0 0deg / 0.03) 76%, transparent 77%, transparent),
      linear-gradient(90deg, transparent 24%, oklch(100% 0 0deg / 0.03) 25%, oklch(100% 0 0deg / 0.03) 26%, transparent 27%, transparent 74%, oklch(100% 0 0deg / 0.03) 75%, oklch(100% 0 0deg / 0.03) 76%, transparent 77%, transparent);
    background-size: 30px 30px;
    pointer-events: none;
    content: '';
    inset: 0;
  }

  /* --- Header --- */
  .sl-header {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
    .sl-header {
      flex-direction: row;
    }
  }

  .sl-icon-circle {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 28px;
    height: 28px;
    border: 2px solid var(--token-white-base, white);
    border-radius: 50%;
    color: var(--token-white-base, white);
    box-shadow: 
      0 0 10px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg)), 
      inset 0 0 6px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  .sl-exclamation {
    font-family: var(--font-primary, sans-serif);
    font-size: 1.1rem;
    font-weight: 900;
    line-height: 1;
    text-shadow: 0 0 8px white;
  }

  .sl-title {
    color: var(--token-white-base, white);
    font-family: var(--font-primary, sans-serif);
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-shadow: 
      0 0 8px var(--grkd-cyan-400, oklch(70% 0.15 195deg)),
      0 0 15px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  @media (min-width: 768px) {
    .sl-title { font-size: 1.5rem; }
  }

  /* --- Content & Rules --- */
  .sl-subtitle {
    margin-bottom: 0.25rem;
    color: var(--token-white-base, white);
    font-family: var(--font-primary, sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    text-shadow: 0 0 6px oklch(100% 0 0deg / 0.5);
  }

  .sl-quest-name {
    margin-bottom: 2rem;
    color: var(--grkd-cyan-400, oklch(70% 0.15 195deg));
    font-family: var(--font-primary, sans-serif);
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-shadow: 0 0 10px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  .sl-rules-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 460px;
    margin: 0 auto;
    text-align: left;
  }

  .sl-rule {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .sl-rule-bullet {
    margin-top: 0.15rem;
    color: var(--grkd-cyan-400, oklch(70% 0.15 195deg));
    font-family: var(--font-pixel, 'Pixelify Sans', sans-serif);
    font-size: 1.1rem;
    line-height: 1;
    text-shadow: 0 0 6px var(--grkd-cyan-400, oklch(70% 0.15 195deg));
  }

  .sl-rule p {
    color: var(--token-white-base, white);
    font-family: var(--font-primary, sans-serif);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    letter-spacing: 0.02em;
    text-shadow: 0 0 4px oklch(100% 0 0deg / 0.4);
  }

  /* --- Action Buttons --- */
  .sl-btn {
    padding: 0.25rem 0.75rem;
    border: 1px solid transparent;
    background: transparent;
    color: var(--grkd-cyan-400, oklch(70% 0.15 195deg));
    font-family: var(--font-pixel, 'Pixelify Sans', sans-serif);
    font-size: 1.25rem;
    letter-spacing: 0.2em;
    cursor: pointer;
    transition: all 0.3s ease;
    text-shadow: 0 0 10px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  .sl-btn:hover {
    color: var(--token-white-base, white);
    text-shadow: 
      0 0 12px white, 
      0 0 20px var(--grkd-cyan-400, oklch(70% 0.15 195deg));
    transform: scale(1.05);
  }

</style>
