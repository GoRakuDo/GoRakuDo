---
/**
 * AwakeningSection.astro
 * Solo Leveling "System Notification" glassmorphism aesthetic.
 */
---

<section
  id="awakening"
  class="relative w-full overflow-hidden py-10 lg:py-24"
  aria-label="Metode Tradisional vs Pendekatan Immersion"
  data-lazy
>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- ==========================================
         ROW 1: TRADITIONAL (2-Column Split)
         ========================================== -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">

      <!-- LEFT: Statue Image -->
      <div class="relative flex justify-center lg:justify-end">
        <div class="statue-glow absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] blur-2xl pointer-events-none"></div>
        <img
          src="/page_images/homepage/old_rules_statue.webp"
          alt="Patung memegang prasasti aturan lama"
          class="relative w-full max-w-[300px] sm:max-w-[360px] lg:max-w-[540px] object-contain mix-blend-luminosity statue-fade"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- RIGHT: Traditional Text -->
      <div class="relative z-10 flex flex-col justify-center text-center lg:text-left">
        <h2 class="traditional-title"><span aria-hidden="true">= </span>従来日本語学習条約<span aria-hidden="true"> =</span></h2>
        <p class="traditional-subtitle">Metode Belajar Bahasa Jepang Tradisional</p>

        <ul class="traditional-rules">
          <li>
            <span class="numeral">I.</span>
            <span>Hafal Mutlak Rumus BUNPOU.</span>
          </li>
          <li>
            <span class="numeral">II.</span>
            <span>Translate Terus Sampai Hafal.</span>
          </li>
          <li>
            <span class="numeral">III.</span>
            <span>Ujian JLPT Menentukan Segalanya.</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- ==========================================
         ROW 2 & 3: AWAKENING SYSTEM (Glassmorphism Hologram)
         ========================================== -->
    <div class="sl-panel-wrapper relative z-20 w-full max-w-2xl mx-auto -mt-4 lg:-mt-12">

      <!-- Glass Body (Navbar-like Glassmorphism) -->
      <div class="sl-glass-body">

        <!-- Header: (!) NOTIFICATION -->
        <header class="sl-header">
          <div class="sl-icon-circle" aria-hidden="true">
            <span class="sl-exclamation">!</span>
          </div>
          <h3 class="sl-title"><span>SYSTEM </span><span>NOTIFICATION</span></h3>
        </header>

        <!-- Content -->
        <div class="sl-content text-center">
          <p class="sl-quest-name">―【 Immersion Awakening 】―</p>

          <div class="sl-rules-list">
            <article class="sl-rule">
              <span class="sl-rule-bullet" aria-hidden="true">&gt;</span>
              <p>Abaikan semua rumus Bunpou.</p>
            </article>
            <article class="sl-rule">
              <span class="sl-rule-bullet" aria-hidden="true">&gt;</span>
              <p>Tidak men-translate Bahasa Jepang ke Indonesia.</p>
            </article>
            <article class="sl-rule">
              <span class="sl-rule-bullet" aria-hidden="true">&gt;</span>
              <p>Pahami Bahasa Jepang malalui konteks.</p>
            </article>
            <article class="sl-rule">
              <span class="sl-rule-bullet" aria-hidden="true">&gt;</span>
              <p>Input bahasa Jepang Non-stop 24x365 hari.</p>
            </article>
          </div>

          <div class="sl-action-container mt-10">
            <p class="sl-action-prompt mb-2 text-[var(--token-white-base)] font-bold tracking-widest text-xs opacity-80">Apakah kamu menerima?</p>
            <div class="flex justify-center gap-8">
              <a href="/panduan-lengkap-otodidak-bahasa-jepang" class="sl-btn sl-btn-accept" aria-label="Terima pendekatan immersion">[ TERIMA ]</a>
            </div>
          </div>

        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* ==========================================================================
     TRADITIONAL SECTION (ROW 1)
     ========================================================================== */

  .statue-glow {
    background: radial-gradient(circle at center, oklch(20% 0.04 20deg / 0.4) 0%, transparent 60%);
  }

  .statue-fade {
    opacity: 0.85;
    filter: drop-shadow(0 10px 30px var(--grkd-black-950, oklch(5% 0.005 270deg)) / 0.8);
    mask-image: linear-gradient(to bottom, var(--grkd-black-950, oklch(5% 0.005 270deg)) 65%, transparent 100%);
  }

  .traditional-title {
    margin-bottom: 0.5rem;
    color: oklch(75% 0.005 270deg / 0.8);
    font-family: var(--font-noto-serif-jp, 'Noto Serif JP', serif);
    font-size: 1.35rem;
    font-weight: 900;
    text-align: center;
    letter-spacing: 0.1em;
  }

  .traditional-title span {
    color: inherit;
  }

  @media (min-width: 640px) {
    .traditional-title { font-size: 1.75rem; }
  }

  @media (min-width: 1024px) {
    .traditional-title { font-size: 2.25rem; }
  }

  .traditional-subtitle {
    margin-bottom: 2rem;
    color: oklch(75% 0.005 270deg / 0.8);
    font-family: var(--font-noto-serif-jp, 'Noto Serif JP', serif);
    font-size: 1rem;
    font-weight: 900; /* Matched to title */
    text-align: center;
    letter-spacing: 0.1em; /* Matched to title */
  }

  @media (min-width: 640px) {
    .traditional-subtitle {
      margin-bottom: 3.5rem;
      font-size: 1.25rem;
    }
  }

  .traditional-rules {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 560px;
    margin: 0;
    padding: 0;
    text-align: left;
    list-style: none;
  }

  @media (min-width: 640px) {
    .traditional-rules { gap: 2rem; }
  }

  @media (max-width: 1023px) {
    .traditional-rules { margin: 0 auto; }
  }

  @media (max-width: 639px) {
    .traditional-rules {
      width: min(100%, 21rem);
      padding-inline: 1rem;
    }
  }

  .traditional-rules li {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    color: oklch(75% 0.005 270deg / 0.8);
    font-family: var(--font-noto-serif-jp, 'Noto Serif JP', serif);
    font-size: 1.05rem;
    font-weight: 750;
    line-height: 1.5;
    letter-spacing: 0.02em;
  }

  @media (min-width: 640px) {
    .traditional-rules li { font-size: 1.35rem; }
  }

  @media (max-width: 639px) {
    .traditional-rules li {
      gap: 1rem;
      font-size: 1rem;
      line-height: 1.45;
    }
  }

  .traditional-rules li span:not(.numeral) {
    color: inherit;
  }

  .traditional-rules .numeral {
    min-width: 2.5rem;
    color: inherit;
    font-size: 1.15em;
    font-weight: 900;
  }

  @media (max-width: 639px) {
    .traditional-rules .numeral { min-width: 2rem; }
  }

  /* ==========================================================================
     SYSTEM HOLOGRAM PANEL (SOLO LEVELING STYLE)
     ========================================================================== */

  .sl-panel-wrapper {
    /* Floating animation */
    animation: floatPanel 6s ease-in-out infinite alternate;
  }

  @keyframes floatPanel {
    0% { transform: translateY(0); }

    100% { transform: translateY(-8px); }
  }

  /* --- Glassmorphism Body (Navbar Style) --- */
  .sl-glass-body {
    position: relative;
    z-index: 1;
    margin: 0 16px; /* Inset from the brackets */
    padding: 1.5rem 1.1rem;

    /* Translucent Blurple border */
    border: 3px solid oklch(65% 0.22 273.85deg / 0.25);
    border-radius: 1.5rem; /* Navbar-like rounded corners */

    /* Deep dark translucent glass */
    background: linear-gradient(
      135deg,
      oklch(15% 0.05 270deg / 0.3) 0%,
      oklch(10% 0.02 270deg / 0.5) 50%,
      oklch(15% 0.05 270deg / 0.3) 100%
    );
    backdrop-filter: blur(16px) saturate(120%); /* Glassmorphism — no scroll ancestors */

    /* Intense Blurple drop shadow + glass inner highlights */
    box-shadow:
      0 10px 40px oklch(65% 0.22 273.85deg / 0.12),
      0 0 20px oklch(65% 0.22 273.85deg / 0.08),
      inset 0 1px 1px oklch(95% 0.005 285deg / 0.1),
      inset 0 -1px 1px oklch(95% 0.005 285deg / 0.02);
  }

  @media (min-width: 768px) {
    .sl-glass-body { padding: 2.5rem 3rem; }
  }

  @media (max-width: 767px) {
    .sl-panel-wrapper {
      padding-bottom: 5.5rem;
    }
  }

  /* Tech Grid Scanline Overlay */
  .sl-glass-body::before {
    position: absolute;
    z-index: -1;
    border-radius: inherit; /* Ensure pattern stays within rounded corners */
    background-image:
      linear-gradient(0deg, transparent 24%, oklch(95% 0.005 285deg / 0.03) 25%, oklch(95% 0.005 285deg / 0.03) 26%, transparent 27%, transparent 74%, oklch(95% 0.005 285deg / 0.03) 75%, oklch(95% 0.005 285deg / 0.03) 76%, transparent 77%, transparent),
      linear-gradient(90deg, transparent 24%, oklch(95% 0.005 285deg / 0.03) 25%, oklch(95% 0.005 285deg / 0.03) 26%, transparent 27%, transparent 74%, oklch(95% 0.005 285deg / 0.03) 75%, oklch(95% 0.005 285deg / 0.03) 76%, transparent 77%, transparent);
    background-size: 30px 30px;
    opacity: 0.5; /* Subtle as requested */
    pointer-events: none;
    content: '';
    inset: 0;
  }

  /* --- Header --- */
  .sl-header {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
    .sl-header {
      flex-direction: row;
    }
  }

  .sl-icon-circle {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 28px;
    height: 28px;
    border: 2px solid var(--token-white-base, oklch(95% 0.005 285deg));
    border-radius: 50%;
    color: var(--token-white-base, oklch(95% 0.005 285deg));
    box-shadow:
      0 0 10px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg)),
      inset 0 0 6px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  .sl-exclamation {
    font-family: var(--font-primary, sans-serif);
    font-size: 1.1rem;
    font-weight: 900;
    line-height: 1;
    text-shadow: 0 0 8px var(--token-white-base, oklch(95% 0.005 285deg));
  }

  .sl-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--token-white-base, oklch(95% 0.005 285deg));
    font-family: var(--font-primary, sans-serif);
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: 0.14em;
    text-shadow:
      0 0 8px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg)),
      0 0 15px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  @media (min-width: 768px) {
    .sl-title {
      flex-direction: row;
      gap: 0.35em;
      font-size: 1.5rem;
    }
  }

  /* --- Content & Rules --- */
  .sl-quest-name {
    overflow: hidden;
    max-width: 100%;
    margin-bottom: 1.5rem;
    color: var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
    font-family: var(--font-primary, sans-serif);
    font-size: clamp(0.8rem, 3.4vw, 1rem);
    font-weight: 800;
    letter-spacing: clamp(0.02em, 0.15vw, 0.05em);
    white-space: nowrap;
    text-overflow: clip;
    text-shadow: 0 0 10px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  @media (min-width: 640px) {
    .sl-quest-name {
      margin-bottom: 2rem;
      font-size: 1.1rem;
      letter-spacing: 0.05em;
    }
  }

  .sl-rules-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 460px;
    margin: 0 auto;
    text-align: left;
  }

  @media (max-width: 639px) {
    .sl-rules-list {
      gap: 0.9rem;
      width: min(100%, 18.75rem);
    }
  }

  .sl-rule {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  @media (max-width: 639px) {
    .sl-rule { gap: 0.65rem; }
  }

  .sl-rule-bullet {
    margin-top: 0.15rem;
    color: var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
    font-family: var(--font-pixel, 'Pixelify Sans', sans-serif);
    font-size: 1.1rem;
    line-height: 1;
    text-shadow: 0 0 6px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  @media (max-width: 639px) {
    .sl-rule-bullet {
      margin-top: 0.2rem;
      font-size: 1rem;
    }
  }

  .sl-rule p {
    color: var(--token-white-base, oklch(95% 0.005 285deg));
    font-family: var(--font-primary, sans-serif);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0.02em;
    text-shadow: 0 0 4px oklch(95% 0.005 285deg / 0.4);
  }

  @media (max-width: 639px) {
    .sl-rule p { line-height: 1.45; }
  }

  /* --- Action Buttons --- */
  .sl-btn {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border: 1px solid transparent;
    background: transparent;
    color: var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
    font-family: var(--font-pixel, 'Pixelify Sans', sans-serif);
    font-size: 1.25rem;
    text-decoration: none;
    letter-spacing: 0.2em;
    cursor: pointer;
    transition: all 0.3s ease;
    text-shadow: 0 0 10px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
  }

  .sl-btn:hover {
    color: var(--token-white-base, oklch(95% 0.005 285deg));
    text-shadow:
      0 0 12px var(--token-white-base, oklch(95% 0.005 285deg)),
      0 0 20px var(--grkd-brand-secondary, oklch(65% 0.22 273.85deg));
    transform: scale(1.05);
  }

</style>
