---
interface Props {
  id: string;
  svgPath: string;
  type: string;
  title: string;
  description: string;
  index?: number;
}

const { id, svgPath, type, title, description, index = 1 } = Astro.props;

// Split title by manual newline (\n) for vertical writing columns
// Reverse order because writing-mode: vertical-rl reads right → left
const titleChunks = title.split('\n').reverse();
---

<article class='feature-card' transition:name={`feature-card-${index}`}>
  <div class='feature-card-glow'></div>
  <div class='feature-card-content'>
    
    <!-- Left Column: Vertical Title -->
    <div class='feature-icon-column'>
      <div class='feature-svg-glow'></div>
      <h3 class='feature-title-vertical'>
        {titleChunks.map((chunk) => (
          <span class='title-chunk'>{chunk}</span>
        ))}
      </h3>
    </div>
    
    <!-- Right Column: ID/Rarity + Description -->
    <div class='feature-text-column'>
      <div class='feature-text-body'>
        <p>{description}</p>
      </div>
      <div class='feature-card-footer'>
        <span class='feature-id'>[ {id} ]</span>
        <span class='feature-rarity'>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rarity-star filled"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rarity-star filled"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rarity-star filled"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rarity-star filled"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rarity-star empty"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
        </span>
      </div>
    </div>

  </div>
</article>
