---
// ========== OPTIMIZED CONTENT GRID COMPONENT ==========
// Centralized data management - this component only handles display logic
// All data processing is done in the parent index.astro

import ToolIdArticle from "./Tool-IdArticle.astro";
import toolsData from "../../data/tools.json";

export interface Props {
  hasArticles: boolean;
  toolArticles: any[];
  tool: string;
  formattedToolName: string;
}

const { hasArticles, toolArticles, tool, formattedToolName } = Astro.props;

// Auto-generate suggestions from tools.json (exclude current tool, show all)
const suggestions = toolsData
  .filter(t => t.id !== tool)
  .map(t => ({ name: t.name, iconUrl: t.iconUrl, href: t.link }));

// Optimized constants for better performance
const EMPTY_STATE_CONFIG = {
  title: `Tutorial ${formattedToolName} Sedang Disiapkan`,
  descriptionLines: [
    `Tutorial tentang ${formattedToolName} sedang dalam tahap penyusunan.`,
    'Akan segera dipublikasikan, mohon tunggu sebentar.',
  ],
  suggestions,
} as const;
---

<!-- Tome Library List Layout -->
<div class="tome-articles-section">
  {hasArticles ? (
    <div class="tome-table-wrapper" role="table" aria-label={`Articles for ${formattedToolName}`}>
      <div class="tome-table-header" role="row">
        <div class="tome-col-date" role="columnheader">日付</div>
        <div class="tome-col-title" role="columnheader">記事タイトル</div>
        <div class="tome-col-tags" role="columnheader">タグ</div>
      </div>
      <div class="tome-table-body" role="rowgroup">
        {toolArticles.map((article, index) => (
          <ToolIdArticle 
            article={article} 
            tool={tool} 
            index={index} 
            role="row"
          />
        ))}
      </div>
    </div>
  ) : (
    <section class="tome-empty-state" role="region" aria-label="No articles available">
      <div class="tome-empty-line" aria-hidden="true"></div>
      <h2 class="tome-empty-title">{EMPTY_STATE_CONFIG.title}</h2>
      <p class="tome-empty-description">
        {EMPTY_STATE_CONFIG.descriptionLines.map((line) => (
          <span>{line}</span>
        ))}
      </p>
      <nav class="tome-empty-actions" aria-label="Alternative navigation">
        <a href="/tools" class="tome-empty-link">Lihat tutorial lain</a>
        <a href="/docs" class="tome-empty-link">Lihat dokumentasi</a>
      </nav>
      {EMPTY_STATE_CONFIG.suggestions.length > 0 && (
        <div class="tome-suggestions" role="list" aria-label="Recommended tools">
          <span class="tome-suggestions-label">Tool terkait:</span>
          {EMPTY_STATE_CONFIG.suggestions.map((suggestion) => (
            <a href={suggestion.href} class="tome-suggestion-link" role="listitem">
              {suggestion.name}
            </a>
          ))}
        </div>
      )}
      <div class="tome-empty-line" aria-hidden="true"></div>
    </section>
  )}
</div>
