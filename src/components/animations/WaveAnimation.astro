---
// WaveAnimation.astro - 静止画背景 (Wave & Torii)
import { Image } from 'astro:assets';
import bgImage from '../../assets/images/typographic_waves_and_torii_1080.webp';

export interface Props {
  className?: string;
  style?: string;
  backgroundLayer?: 'normal' | 'darker';
}

const config = {
  className: '',
  style: '',
  backgroundLayer: 'normal',
  ...Astro.props,
};
---

<div
  class={`static-background-container ${config.className}`}
  style={config.style}
  data-background-layer={config.backgroundLayer}
>
  <Image
    src={bgImage}
    alt="Background"
    class="static-background-image"
    quality="high"
    loading="eager"
  />

  <!-- 他のページ用に、あらかじめ全面をぼかすためのレイヤー（トップページではJSかCSSで制御） -->
  <div id="global-blur-layer" class="global-blur-layer"></div>
</div>

<style is:global>
  .static-background-container {
    position: fixed;
    z-index: var(--z-WaveAnimation-wave-animation-container, -2);
    width: 100vw;
    height: 100vh;
    background-color: var(--grkd-black-950);
    pointer-events: none;
    inset: 0;
  }

  .static-background-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.85; /* 少し暗くしてテキストを読みやすく */
  }

  /* 他のページでは最初から全体をぼかす。トップページではHero部分のみクリアにする */
  .global-blur-layer {
    position: absolute;
    background: rgb(0 0 0 / 0.4); /* 暗くするTint */
    opacity: 1; /* デフォルトはON (他のページ用) */
    transition: opacity 0.3s ease;
    inset: 0;
    backdrop-filter: blur(20px);
  }

  /* トップページの時は、このレイヤーを非表示（または後述の別レイヤーで段階的にぼかす） */
  body[data-page="home"] .global-blur-layer {
    opacity: 0;
  }
</style>

<script>
  // トップページかどうかを判定して body に data-page="home" を付与
  const setPageType = () => {
    if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
      document.body.setAttribute('data-page', 'home');
    } else {
      document.body.removeAttribute('data-page');
    }
  };

  setPageType();
  document.addEventListener('astro:page-load', setPageType);
</script>
