---
// WaveAnimation.astro - 静止画背景 (Wave & Torii)
import { Image } from 'astro:assets';
import bgImage from '../../assets/images/typographic_waves_and_torii_1080.webp';

export interface Props {
  className?: string;
  style?: string;
  backgroundLayer?: 'normal' | 'darker';
}

const config = {
  className: '',
  style: '',
  backgroundLayer: 'normal',
  ...Astro.props,
};
---

<div
  class={`static-background-container ${config.className}`}
  style={config.style}
  data-background-layer={config.backgroundLayer}
>
  <Image
    src={bgImage}
    alt="Background"
    class="static-background-image"
    quality="low" 
    loading="eager"
  />
</div>

<style is:global>
  .static-background-container {
    position: fixed;
    z-index: var(--z-WaveAnimation-wave-animation-container, -2);
    width: 100vw;
    height: 100vh;
    background-color: var(--grkd-black-950);
    pointer-events: none;
    inset: 0;
  }

  .static-background-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;

    /* 
      圧倒的なパフォーマンス改善：
      スクロールラグの原因となる backdrop-filter を廃止し、
      画像自体に軽量な静的 filter をかけることでGPU負荷をゼロにする
    */
    filter: blur(16px) brightness(0.35); 
    transform: scale(1.1); /* ぼかしの端が透けないように画像全体を10%拡大（ズレ防止） */
  }
</style>
