---
// WaveAnimation.astro - 静止画背景 (Wave & Torii)
import { Image } from 'astro:assets';
import bgImage from '../../assets/images/typographic_waves_and_torii_8bit_1080_blurred.webp';

export interface Props {
  className?: string;
  style?: string;
  backgroundLayer?: 'normal' | 'darker';
}

const config = {
  className: '',
  style: '',
  backgroundLayer: 'normal',
  ...Astro.props,
};
---

<div
  class={`static-background-container ${config.className}`}
  style={config.style}
  data-background-layer={config.backgroundLayer}
>
  <Image
    src={bgImage}
    alt="Background"
    class="static-background-image"
    quality="low" 
    loading="eager"
  />
</div>

<style is:global>
  .static-background-container {
    position: fixed;
    z-index: var(--z-WaveAnimation-wave-animation-container, -2);
    width: 100vw;
    height: 100vh;
    background-color: var(--grkd-black-950);
    pointer-events: none;
    inset: 0;
  }

  .static-background-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;

    /* 
      究極のパフォーマンス改善：
      あらかじめPhotoshopでぼかした画像を使用することで、ブラウザの blur 負荷を完全にゼロにする。
      （暗くする処理だけはCSSで残しています）
    */
    filter: brightness(0.35); 
    transform: translateZ(0) scale(1.1); /* 画像全体を10%拡大（ズレ防止）し、GPUにテクスチャとして固定 */
    will-change: transform;
  }
</style>
