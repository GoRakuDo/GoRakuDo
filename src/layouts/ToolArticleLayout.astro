---
// ========== IMPORTS ==========
import UnifiedSEO, {
  type Props as UnifiedSEOProps,
} from '../components/UnifiedSEO.astro';
import Navbar from '../components/common/NavBar/Navbar.astro';
import BottomNavBar from '../components/common/NavBar/BottomNavBar.astro';
import WaveAnimation from '../components/animations/WaveAnimation.astro';
import Prose from '../components/Prose.astro';
import '../styles/global.css';
import '../styles/pages/tools/[tool]/ToolArticleLayout.css';

// ========== TYPE DEFINITIONS ==========
export interface RelatedTool {
  name: string;
  slug: string;
  icon: string;
}

export interface NavArticle {
  title: string;
  slug: string;
}

export interface Props {
  title: string;
  description: string;
  publishedDate?: string;
  modifiedDate?: string;
  lang?: 'id' | 'ja';
  author?: string;
  tags?: string[];
  image?: string;
  toolName: string;
  toolIcon: string;
  devicePlatform?: string;
  readingTimeMin?: number;
  breadcrumbSchema?: UnifiedSEOProps['breadcrumbSchema'];
  softwareApplicationSchema?: UnifiedSEOProps['softwareApplicationSchema'];
  articleSection?: string;
  prevArticle?: NavArticle | null;
  nextArticle?: NavArticle | null;
  relatedTools?: RelatedTool[];
}

// ========== PROPS DESTRUCTURING ==========
const {
  title,
  description,
  publishedDate,
  modifiedDate,
  lang = 'id',
  author,
  tags = [],
  image,
  toolName,
  toolIcon,
  devicePlatform,
  readingTimeMin,
  breadcrumbSchema,
  softwareApplicationSchema,
  articleSection,
  prevArticle = null,
  nextArticle = null,
  relatedTools = [],
} = Astro.props;

const formattedDate = publishedDate
  ? new Date(publishedDate).toLocaleDateString('id-ID', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

// OS icon map (sourced from thesvg.org / simple-icons v11) — same
// source as Tool-IdArticle.astro to keep the table index and hero
// visually consistent.
const OS_ICONS: Record<string, { label: string; svg: string }> = {
  Android: {
    label: 'Android',
    svg: '<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><title>Android</title><path fill="currentColor" d="M18.4395 5.5586c-.675 1.1664-1.352 2.3318-2.0274 3.498-.0366-.0155-.0742-.0286-.1113-.043-1.8249-.6957-3.484-.8-4.42-.787-1.8551.0185-3.3544.4643-4.2597.8203-.084-.1494-1.7526-3.021-2.0215-3.4864a1.1451 1.1451 0 0 0-.1406-.1914c-.3312-.364-.9054-.4859-1.379-.203-.475.282-.7136.9361-.3886 1.5019 1.9466 3.3696-.0966-.2158 1.9473 3.3593.0172.031-.4946.2642-1.3926 1.0177C2.8987 12.176.452 14.772 0 18.9902h24c-.119-1.1108-.3686-2.099-.7461-3.0683-.7438-1.9118-1.8435-3.2928-2.7402-4.1836a12.1048 12.1048 0 0 0-2.1309-1.6875c.6594-1.122 1.312-2.2559 1.9649-3.3848.2077-.3615.1886-.7956-.0079-1.1191a1.1001 1.1001 0 0 0-.8515-.5332c-.5225-.0536-.9392.3128-1.0488.5449zm-.0391 8.461c.3944.5926.324 1.3306-.1563 1.6503-.4799.3197-1.188.0985-1.582-.4941-.3944-.5927-.324-1.3307.1563-1.6504.4727-.315 1.1812-.1086 1.582.4941zM7.207 13.5273c.4803.3197.5506 1.0577.1563 1.6504-.394.5926-1.1038.8138-1.584.4941-.48-.3197-.5503-1.0577-.1563-1.6504.4008-.6021 1.1087-.8106 1.584-.4941z"/></svg>',
  },
  Windows: {
    label: 'Windows 11',
    svg: '<svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><title>Windows 11</title><path fill="currentColor" d="M0,0H11.377V11.372H0ZM12.623,0H24V11.372H12.623ZM0,12.623H11.377V24H0Zm12.623,0H24V24H12.623"/></svg>',
  },
};

const osIcon = devicePlatform ? OS_ICONS[devicePlatform] : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <UnifiedSEO
      title={title}
      description={description}
      keywords={tags}
      lang={lang}
      pageType='article'
      image={image}
      author={author}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate || publishedDate}
      articleSection={articleSection}
      breadcrumbSchema={breadcrumbSchema}
      softwareApplicationSchema={softwareApplicationSchema}
    />
  </head>
  <body>
    <Navbar />
    <BottomNavBar />
    <WaveAnimation backgroundLayer='normal' />

    <div class='tqa-page'>
      <!-- Breadcrumb Slot -->
      <div class='tqa-breadcrumb-slot'>
        <slot name='breadcrumb' />
      </div>

      <!-- Tome Hero -->
      <header class='tqa-hero' role='banner'>
        <p class='tqa-hero-marker' aria-hidden='true'>
          /// ARTICLE_OPEN ///
        </p>

        <div class='tqa-hero-card'>
          <div class='tqa-hero-grid'>
            <div class='tqa-hero-icon-wrap'>
              <img
                class='tqa-hero-icon'
                src={toolIcon}
                alt={`${toolName} icon`}
                width='160'
                height='160'
                loading='eager'
                decoding='async'
              />
            </div>

            <div class='tqa-hero-content'>
              <h1 class='tqa-hero-title'>{title}</h1>
              <div class='tqa-hero-meta' aria-label='Article metadata'>
                {
                  formattedDate && (
                    <time
                      class='tqa-hero-meta-item'
                      datetime={publishedDate}
                    >
                      {formattedDate}
                    </time>
                  )
                }
                {author && <span class='tqa-hero-meta-item'>{author}</span>}
                {devicePlatform && (
                  <span class='tqa-hero-meta-item tqa-hero-meta-os'>
                    {osIcon && (
                      <span
                        class='tqa-hero-meta-os-icon'
                        role='img'
                        aria-label={osIcon.label}
                        title={osIcon.label}
                        set:html={osIcon.svg}
                      />
                    )}
                    {devicePlatform}
                  </span>
                )}
                {readingTimeMin !== undefined && (
                  <span class='tqa-hero-meta-item'>
                    {readingTimeMin} min read
                  </span>
                )}
              </div>
              <p class='tqa-hero-description'>{description}</p>
            </div>
          </div>
        </div>
      </header>

      <!-- 2-column Quest Codex grid -->
      <div class='tqa-grid'>
        <!-- Left: Prev/Next nav + TOC (sticky on ≥1280px) -->
        <aside class='tqa-left' aria-label='Article navigation and contents'>
          <nav class='tqa-aside-nav' aria-label='Navigasi artikel'>
            {
              prevArticle ? (
                <a
                  class='tqa-nav-card tqa-nav-prev'
                  href={prevArticle.slug}
                  rel='prev'
                >
                  <span class='tqa-nav-direction'>◀ Sebelumnya</span>
                  <span class='tqa-nav-title'>{prevArticle.title}</span>
                </a>
              ) : (
                <div
                  class='tqa-nav-card tqa-nav-disabled'
                  aria-disabled='true'
                >
                  <span class='tqa-nav-direction'>◀ Artikel pertama</span>
                </div>
              )
            }
            {
              nextArticle ? (
                <a
                  class='tqa-nav-card tqa-nav-next'
                  href={nextArticle.slug}
                  rel='next'
                >
                  <span class='tqa-nav-direction'>Selanjutnya ▶</span>
                  <span class='tqa-nav-title'>{nextArticle.title}</span>
                </a>
              ) : (
                <div
                  class='tqa-nav-card tqa-nav-disabled'
                  aria-disabled='true'
                >
                  <span class='tqa-nav-direction'>Artikel terbaru ▶</span>
                </div>
              )
            }
          </nav>

          {
            relatedTools.length > 0 && (
              <section
                class='tqa-related'
                aria-labelledby='tqa-related-title'
              >
                <h2 class='tqa-related-title' id='tqa-related-title'>
                  Tools Terkait
                </h2>
                <ul class='tqa-related-list'>
                  {relatedTools.map(rel => (
                    <li>
                      <a
                        class='tqa-related-card'
                        href={`/tools/${rel.slug}`}
                        aria-label={`Buka halaman detail ${rel.name}`}
                      >
                        <img
                          class='tqa-related-icon'
                          src={rel.icon}
                          alt=''
                          width='32'
                          height='32'
                          loading='lazy'
                          decoding='async'
                        />
                        <span class='tqa-related-name'>{rel.name}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            )
          }

          <aside class='tqa-toc' aria-label='Table of contents'>
            <slot name='toc' />
          </aside>
        </aside>

        <!-- Center: Quest Entries -->
        <main class='tqa-main' role='main'>
          <article class='tqa-article' id='main-content'>
            <Prose>
              <slot />
            </Prose>
          </article>

          <!-- End of Chapter -->
          <footer class='tqa-end' role='contentinfo'>
            <p class='tqa-end-marker' aria-hidden='true'>
              /// ARCHIVE_CLOSE ///
            </p>

            <div class='tqa-end-actions'>
              <slot name='end-actions' />
            </div>
          </footer>
        </main>
      </div>
    </div>
  </body>
</html>
